# ──────────────────────────────────────────────────────────────
#  환경설정(.env) — 인증키를 여기에 적으면 앱이 자동으로 읽습니다.
#  · 값은 따옴표 없이 = 뒤에 바로 붙여넣으세요.   예)  VISION_API_KEY=AIzaSy...
#  · 이 파일은 비밀 정보라 git 에 올라가지 않습니다(.gitignore).
#  · 설정 화면(설정 → 축산·사료)에 입력한 값이 있으면 그 값이 우선합니다.
#  · 수정 후에는 앱(서버)을 다시 시작해야 반영됩니다.
# ──────────────────────────────────────────────────────────────

# 📷 이표 사진 자동입력 — Google Cloud Vision API 키
VISION_API_KEY=AIzaSyB2on_0BHU7IJZ9H3wRSy1p2mZJE4B0qJA

# 🐄 이표번호 자동조회(축산물이력제) — 공공데이터포털 인증키(Encoding)
EKAPE_SERVICE_KEY=AIzaSyB2on_0BHU7IJZ9H3wRSy1p2mZJE4B0qJA

# 🛠 개발자/운영 콘솔 접속 키 — 값을 넣으면 /console 에서 이 키로 로그인
CONSOLE_KEY=

# (선택) 로그인 세션 서명 키 — 인터넷 공개 배포 시 임의의 긴 문자열로 지정
# SECRET_KEY=

# (선택) 데이터 저장 폴더 — 클라우드/영구디스크 경로 지정용
# DATA_DIR=

# (선택) 실행 포트 (기본 8000)
# PORT=8000
